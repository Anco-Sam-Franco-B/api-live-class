# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# JWT
JWT_SECRET=your-jwt-secret-key
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REMEMBER_EXPIRES_IN=30d

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com

# Frontend URL
CLIENT_URL=http://localhost:5173

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# 8x8.vc (JaaS) - https://jaas.8x8.vc
JAAS_APP_ID=vpaas-magic-cookie-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# JAAS_API_KEY is the app key (API Key) from the JaaS dashboard
JAAS_API_KEY=
# JAAS_PRIVATE_KEY is the RSA PRIVATE KEY downloaded from the JaaS dashboard
# Must be PEM format, used for RS256 JWT signing
JAAS_PRIVATE_KEY=
JAAS_DOMAIN=8x8.vc

# MTN MoMo
MTN_MOMO_API_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_COLLECTION_PRIMARY_KEY=
MTN_MOMO_PROVIDER_CALLBACK_HOST=http://localhost:5000

# Airtel Money
AIRTEL_MONEY_API_KEY=
AIRTEL_MONEY_ENVIRONMENT=sandbox
AIRTEL_MONEY_CLIENT_ID=
AIRTEL_MONEY_CLIENT_SECRET=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10000
